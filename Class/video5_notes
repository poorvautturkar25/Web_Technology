### Example Code Snippets  

**Function Definition and Call:**  
```js
function greet(name) {
  console.log("Hello " + name);
}
greet("Alice"); // Prints: Hello Alice
```

**Arrow Function:**  
```js
const sum = (a, b) => a + b;
console.log(sum(3, 4)); // Outputs: 7
```

**Counting Vowels:**  
```js
function countVowels(str) {
  let count = 0;
  for(let char of str.toLowerCase()) {
    if("aeiou".includes(char)) count++;
  }
  return count;
}
console.log(countVowels("hello")); // Outputs: 2
```

**Using `forEach`:**  
```js
const arr = [1, 2, 3];
arr.forEach(num => console.log(num)); // Prints 1, 2, 3
```

**Using `map`:**  
```js
const squared = arr.map(num => num * num);
console.log(squared); // [1, 4, 9]
```

**Using `filter`:**  
```js
const evens = arr.filter(num => num % 2 === 0);
console.log(evens); // [2]
```

**Using `reduce` for sum:**  
```js
const sum = arr.reduce((acc, val) => acc + val, 0);
console.log(sum); // 6
```

**Using `reduce` for max:**  
```js
const max = arr.reduce((prev, curr) => (prev > curr ? prev : curr));
console.log(max); // 3
```

